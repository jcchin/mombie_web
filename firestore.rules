rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — any signed-in user can read (needed to look up invite targets);
    // only the owner can write their own doc
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Invite codes — any signed-in user can look up; only owner creates
    match /inviteCodes/{code} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                      request.resource.data.uid == request.auth.uid;
    }

    // Families — any signed-in user can read (needed to check capacity before joining);
    // create: requester must be in the new member list (size 2–9);
    // update: existing member making changes, OR a non-member adding only themselves (+1)
    match /families/{familyId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
                      request.auth.uid in request.resource.data.memberIds &&
                      request.resource.data.memberIds.size() >= 2 &&
                      request.resource.data.memberIds.size() <= 9;

      allow update: if request.auth != null &&
                      request.resource.data.memberIds.size() <= 9 &&
                      request.resource.data.memberIds.toSet().hasAll(resource.data.memberIds.toSet()) &&
                      (
                        // Existing member making changes
                        request.auth.uid in resource.data.memberIds ||
                        // Non-member adding only themselves (join via invite)
                        (request.auth.uid in request.resource.data.memberIds &&
                         request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1)
                      );
    }

    // Baby logs — owner writes; all family members can read
    match /babyLogs/{uid}/entries/{entryId} {
      allow read:  if request.auth != null &&
                     (request.auth.uid == uid || isInSameFamily(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Returns true if the requesting user is in the same family as {uid}.
    // Looks up the REQUESTER's familyId (guaranteed set after joining)
    // and checks that {uid} is also a member — avoids relying on {uid}'s
    // profile having familyId set before their next login.
    function isInSameFamily(uid) {
      let myDoc    = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let familyId = myDoc.data.familyId;
      return familyId != null &&
             exists(/databases/$(database)/documents/families/$(familyId)) &&
             uid in
               get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
    }
  }
}
