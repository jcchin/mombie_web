rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — owner read/write; family members can read
    match /users/{uid} {
      allow read:  if request.auth != null &&
                     (request.auth.uid == uid || isInSameFamily(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Invite codes — any signed-in user can look up; only owner creates
    match /inviteCodes/{code} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                      request.resource.data.uid == request.auth.uid;
    }

    // Families — members can read; members can create (2–6) or add new members
    match /families/{familyId} {
      allow read: if request.auth != null &&
                    request.auth.uid in resource.data.memberIds;

      allow create: if request.auth != null &&
                      request.auth.uid in request.resource.data.memberIds &&
                      request.resource.data.memberIds.size() >= 2 &&
                      request.resource.data.memberIds.size() <= 6;

      allow update: if request.auth != null &&
                      request.auth.uid in resource.data.memberIds &&
                      request.resource.data.memberIds.size() <= 6 &&
                      // existing members cannot be removed
                      resource.data.memberIds.toSet().hasAll(request.resource.data.memberIds.toSet().difference(resource.data.memberIds.toSet()) == [] ? resource.data.memberIds : resource.data.memberIds);
    }

    // Baby logs — owner writes; all family members can read
    match /babyLogs/{uid}/entries/{entryId} {
      allow read:  if request.auth != null &&
                     (request.auth.uid == uid || isInSameFamily(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Returns true if the requesting user is in the same family as {uid}
    function isInSameFamily(uid) {
      let userDoc  = get(/databases/$(database)/documents/users/$(uid));
      let familyId = userDoc.data.familyId;
      return familyId != null &&
             exists(/databases/$(database)/documents/families/$(familyId)) &&
             request.auth.uid in
               get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
    }
  }
}
